<idea-plugin>
  <id>com.lottiepreview.plugin</id>
  <name>Lottie Preview</name>
  <vendor>Lottie Preview</vendor>
  <description><![CDATA[
    Preview Lottie and dotLottie animations directly inside IntelliJ-based IDEs.
  ]]></description>

  <depends>com.intellij.modules.platform</depends>

  <extensions defaultExtensionNs="com.intellij">
    <toolWindow
      id="Lottie Preview"
      anchor="right"
      icon="com.lottiepreview.plugin.ui.LottieIcons.ToolWindow"
      factoryClass="com.lottiepreview.plugin.toolwindow.LottiePreviewWindowFactory"/>
  </extensions>

  <projectListeners>
    <listener
      class="com.lottiepreview.plugin.file.LottieFileListener"
      topic="com.intellij.openapi.fileEditor.FileEditorManagerListener"/>
    <listener
      class="com.lottiepreview.plugin.file.LottieVfsListener"
      topic="com.intellij.openapi.vfs.newvfs.BulkFileListener"/>
  </projectListeners>

  <actions>
    <action
      id="com.lottiepreview.OpenLottieAction"
      class="com.lottiepreview.plugin.actions.OpenLottieAction"
      text="Open in Lottie Preview"
      icon="com.lottiepreview.plugin.ui.LottieIcons.Action"
      description="Preview this Lottie animation in the IDE">
      <add-to-group group-id="ProjectViewPopupMenu" anchor="after" relative-to-action="RevealIn"/>
    </action>
  </actions>
</idea-plugin>
